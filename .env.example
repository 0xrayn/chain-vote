# ─── ChainVotes — Environment Variables ────────────────────────────────────
# Copy this file to .env.local and fill in your values

# Your wallet private key (deployer). DO NOT commit to git!
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Sepolia RPC URL — use Alchemy or Infura for reliability
# Free: https://www.alchemy.com  or  https://app.infura.io
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Etherscan API key — for contract verification (optional but recommended)
# Get one free at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Auto-filled by deploy script (scripts/deploy.ts):
NEXT_PUBLIC_CONTRACT_ADDRESS=
